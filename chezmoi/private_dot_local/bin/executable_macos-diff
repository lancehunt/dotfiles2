#!/bin/bash
# Diff current macOS defaults against the last macos-snapshot.
# Output shows domain, key, type, and value — everything needed to write
# a defaults write command:
#   defaults write <domain> <key> -<type> <value>
#
# Type reference:
#   <true/> / <false/>     → -bool true / -bool false
#   <integer>N</integer>   → -int N
#   <real>N</real>         → -float N
#   <string>s</string>     → -string "s"
#   <array>...</array>     → -array ...
#   <dict>...</dict>       → -dict-add ...

SNAPSHOT_DIR="${TMPDIR:-/tmp}/macos-defaults-snapshot"

if [ ! -d "$SNAPSHOT_DIR" ]; then
  echo "No snapshot found. Run macos-snapshot first."
  exit 1
fi

DOMAINS=(
  "NSGlobalDomain"
  "com.apple.dock"
  "com.apple.finder"
  "com.apple.screencapture"
  "com.apple.HIToolbox"
  "com.apple.driver.AppleBluetoothMultitouch.trackpad"
  "com.apple.AppleMultitouchTrackpad"
  "com.apple.universalaccess"
  "com.apple.controlcenter"
  "com.apple.menuextra.clock"
  "com.apple.systempreferences"
  "com.apple.loginwindow"
)

CURRENT_DIR="${TMPDIR:-/tmp}/macos-defaults-current"
mkdir -p "$CURRENT_DIR"

found_changes=false

for domain in "${DOMAINS[@]}"; do
  defaults export "$domain" "$CURRENT_DIR/$domain.plist" 2>/dev/null || true
  [ -f "$CURRENT_DIR/$domain.plist" ] && plutil -convert xml1 "$CURRENT_DIR/$domain.plist"

  before="$SNAPSHOT_DIR/$domain.plist"
  after="$CURRENT_DIR/$domain.plist"

  if [ ! -f "$before" ] && [ ! -f "$after" ]; then
    continue
  fi

  diff_output=$(diff -u "${before:-/dev/null}" "${after:-/dev/null}")
  if [ -n "$diff_output" ]; then
    echo "=== $domain ==="
    echo "$diff_output"
    echo ""
    found_changes=true
  fi
done

if [ "$found_changes" = false ]; then
  echo "No changes detected."
fi

#!/bin/bash

# Git custom command to safely update all git repositories in subdirectories
# Usage: git update-all

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

echo "Safely updating all git repositories in subdirectories..."
echo "================================================================"

# Arrays to track which repos fall into each category
declare -a updated=()
declare -a skipped=()
declare -a failed=()

# Store current directory so we can always return to it
START_DIR=$(pwd)

# Process each subdirectory
for dir in */; do
    # Remove the trailing slash from directory name
    dir=${dir%/}

    # Check if this is a directory containing a git repository
    if [ -d "$dir" ] && [ -d "$dir/.git" ]; then
        echo -e "\n${YELLOW}Processing: $dir${NC}"

        # Try to change into the repository directory
        if ! cd "$START_DIR/$dir"; then
            failed+=("$dir")
            continue
        fi

        # Fetch from all remotes and prune stale branches
        echo -e "${BLUE}Fetching from remotes and pruning...${NC}"
        if ! git remote update -p; then
            echo -e "${RED}✗ Failed to fetch from remotes in $dir${NC}"
            failed+=("$dir")
            cd "$START_DIR"
            continue
        fi

        # Attempt to merge with fast-forward only
        echo -e "${BLUE}Attempting fast-forward merge...${NC}"
        if git merge --ff-only @{u} 2>/dev/null; then
            echo -e "${GREEN}✓ Successfully updated $dir${NC}"
            updated+=("$dir")
        else
            # The merge failed - check if we're already up to date
            if git status | grep -q "Your branch is up to date"; then
                echo -e "${GREEN}✓ Already up to date${NC}"
                updated+=("$dir")
            else
                echo -e "${YELLOW}⚠ Cannot fast-forward (may have local commits or no upstream)${NC}"
                echo -e "${YELLOW}  This repository needs manual attention${NC}"
                skipped+=("$dir")
            fi
        fi

        # Return to parent directory before next iteration
        cd "$START_DIR"

    elif [ -d "$dir" ]; then
        # This is a directory but not a git repository
        echo -e "\n${YELLOW}Processing: $dir${NC}"
        echo "Not a git repository, skipping..."
    fi
done

# Calculate total and print summary
total_repos=$((${#updated[@]} + ${#skipped[@]} + ${#failed[@]}))
echo -e "\n================================================================"
echo "Update Summary:"
echo "  Total repositories found: $total_repos"
echo -e "  ${GREEN}Successfully updated: ${#updated[@]}${NC}"

if [ ${#skipped[@]} -gt 0 ]; then
    echo -e "  ${YELLOW}Needs manual attention: ${#skipped[@]}${NC}"
fi

if [ ${#failed[@]} -gt 0 ]; then
    echo -e "  ${RED}Failed: ${#failed[@]}${NC}"
fi

echo "================================================================"
